# TARS Contact Form Backend — Environment Configuration
# Copy this file to .env and fill in your values

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable debug mode (verbose errors, auto-reload)
DEBUG=false

# CORS allowed origins (comma-separated, or * for all)
# Set this to your frontend URL in production, e.g. https://yourdomain.com
ALLOWED_ORIGINS=*

# Application name (used in logs and metadata)
APP_NAME=TARS Contact Backend

# Who receives the contact form emails
RECEIVER_EMAIL=your-email@gmail.com

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_USE_TLS=true
